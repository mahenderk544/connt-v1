{
  "family": "__TASK_FAMILY__",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "__CPU__",
  "memory": "__MEMORY__",
  "executionRoleArn": "__EXECUTION_ROLE_ARN__",
__TASK_ROLE_LINE__
  "containerDefinitions": [
    {
      "name": "__CONTAINER_NAME__",
      "image": "__IMAGE_URI__",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" },
        {
          "name": "SPRING_DATASOURCE_URL",
          "value": "__JDBC_URL__"
        },
        { "name": "SPRING_DATASOURCE_USERNAME", "value": "__DB_USERNAME__" }
      ],
      "secrets": [
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "valueFrom": "__RDS_PASSWORD_SECRET_ARN__"
        },
        {
          "name": "CONNTO_JWT_SECRET",
          "valueFrom": "__JWT_SECRET_ARN__"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "__LOG_GROUP__",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
